# ========================================
#  灵犀智购 — 环境配置
#  复制为 .env 并填入真实值
#  cp .env.example .env
# ========================================

# ── DeepSeek 大模型 ────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── 视觉模型 (通义千问 VL, 用于图片分析) ──
VISION_API_KEY=sk-your-dashscope-key
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-plus

# ── Ollama (本地 Embedding 向量匹配) ──
# Docker 用户: OLLAMA_BASE_URL=http://ollama:11434
# 本地用户:   OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3

# ── MySQL 数据库 ────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=constomer

# ── Neo4j 图数据库 (本地 Docker) ──────
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=12345678
NEO4J_DATABASE=neo4j

# ── JWT 认证 ────────────────────────────
# 生产环境请用: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS 跨域 ────────────────────────────
# 生产环境改为实际域名, 逗号分隔
ALLOWED_ORIGINS=*

# ── Embedding 向量配置 ─────────────────
EMBEDDING_TYPE=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_THRESHOLD=0.90

# ── Milvus 向量数据库 (预定义查询匹配) ──
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=predefined_cypher_vectors

# ── SQLite 检查点 (LangGraph 对话记忆) ──
CHECKPOINT_DB_PATH=checkpoints.db
